## Repository 与查询

```typescript
// ❌ BAD — N+1、SELECT *、无分页上界
async listWithDetails() {
  const items = await Item.query();
  for (const item of items) {
    item.tags = await item.$relatedQuery('tags');
  }
  return items;
}

// ✅ GOOD
async listPage(input: ListInput): Promise<Page<Item>> {
  const { page, pageSize } = input;
  return Item.query()
    .select('items.id', 'items.name', 'items.status', 'items.createdAt')
    .withGraphFetched('tags(selectBasic)')
    .orderBy('items.createdAt', 'desc')
    .page(page, Math.min(pageSize, 100));
}
```

