## Apollo GraphQL 调用

```tsx
// ❌ BAD — 无错误处理、无 loading、mutation 后不失效缓存
function DeleteButton({ id }: { id: string }) {
  const [remove] = useDeleteItemMutation();
  return <Button onClick={() => remove({ variables: { id } })}>删除</Button>;
}

// ✅ GOOD
function DeleteButton({ id }: { id: string }) {
  const [remove, { loading }] = useDeleteItemMutation({
    refetchQueries: [{ query: ListItemsDocument }],
    onError: (err) => message.error(err.message),
  });
  return (
    <Button
      danger
      loading={loading}
      onClick={() => remove({ variables: { id } })}
    >
      删除
    </Button>
  );
}
```

