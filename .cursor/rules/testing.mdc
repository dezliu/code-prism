## 单元测试示例

```typescript
// ❌ BAD — 测实现、无边界、依赖真实 DB
it('works', async () => {
  const svc = new SearchUseCase(realQdrant, realRedis);
  const result = await svc.execute({ query: 'test' });
  expect(svc.embedder.embed).toHaveBeenCalledTimes(1);
});

// ✅ GOOD — 测行为、Mock 边界、覆盖异常
describe('SearchKnowledgeUseCase', () => {
  it('should return cached results when cache hit', async () => {
    const cached = [{ id: '1', score: 0.9 }];
    const cache = { get: vi.fn().mockResolvedValue(cached), set: vi.fn() };
    const useCase = new SearchKnowledgeUseCase(mockEmbedder, mockVectorStore, cache, mockLogger);

    const result = await useCase.execute({ query: 'hello', limit: 10 }, 'trace-1');

    expect(result).toEqual(cached);
    expect(mockEmbedder.embed).not.toHaveBeenCalled();
  });

  it('should propagate DomainError when collection not found', async () => {
    mockVectorStore.search.mockRejectedValue(new CollectionNotFoundError('kb'));
    await expect(useCase.execute(input, 'trace-2')).rejects.toThrow(CollectionNotFoundError);
  });
});
```

