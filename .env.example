# =============================================================================
# 灵镜 (LingPrism) — 环境变量模板
# 复制为 .env 后填入实际值：cp .env.example .env
# =============================================================================

# === 通用 ===
NODE_ENV=development
LOG_LEVEL=info
TRACE_ENABLED=true

# === 前端 ===
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# === API (Node) ===
API_PORT=4000
DATABASE_URL=mysql://lingprism:lingprism@localhost:13306/lingprism
REDIS_URL=redis://localhost:6380/0
CORE_GRPC_ADDR=localhost:50051
AI_WORKER_URL=http://localhost:8001
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# === Core (Go) ===
CORE_HTTP_PORT=8080
CORE_GRPC_PORT=50051
MYSQL_DSN=lingprism:lingprism@tcp(localhost:3306)/lingprism?parseTime=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lingprism
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=lingprism_v1_zhipu_1024
ZHIPU_EMBEDDING_DIM=1024
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=lingprism
INDEXER_GRPC_ADDR=localhost:50052

# === AI Worker (Python) ===
AI_WORKER_HTTP_PORT=8001
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 默认 Chat 厂商：deepseek | qwen | zhipu | openai
LLM_PROVIDER=zhipu
EMBEDDING_PROVIDER=zhipu

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# 通义千问 / 阿里云百炼
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 智谱 AI
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus
ZHIPU_EMBEDDING_MODEL=embedding-3

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

LLM_SCENE_QA_MODEL=
LLM_SCENE_INTENT_MODEL=glm-4-flash
LLM_SCENE_DOC_GEN_MODEL=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3003

# === MCP (Python) ===
MCP_PORT=8090
MCP_API_KEYS=dev-key-1,dev-key-2
MCP_PROTOCOL_VERSION=2025-03-26
LINGPRISM_INTERNAL_API_URL=http://localhost:8080

# === 基础设施（docker-compose） ===
MYSQL_ROOT_PASSWORD=lingprism
MYSQL_DATABASE=lingprism
MYSQL_USER=lingprism
MYSQL_PASSWORD=lingprism
