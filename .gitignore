# =============================================================================
# 灵镜 (LingPrism) — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# CodeGraph — 本地代码图谱索引（每台机器独立，勿提交）
# -----------------------------------------------------------------------------
.codegraph/
.codegraph-*/

# -----------------------------------------------------------------------------
# 环境变量与密钥
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
!.env*.example

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Rust（代码解析 / tree-sitter）
# -----------------------------------------------------------------------------
target/
**/*.rs.bk

# -----------------------------------------------------------------------------
# Go（核心后端）
# -----------------------------------------------------------------------------
bin/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html
*.prof
go.work
go.work.sum

# -----------------------------------------------------------------------------
# Node.js / Next.js 14 / React 18 / Apollo GraphQL / Objection.js
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js
.next/
out/
.vercel

# 构建产物
dist/
build/
*.tsbuildinfo

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Python（MCP 服务 / LangChain / Celery）
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
.venv/
venv/
env/
ENV/
.env.bak

# 打包与分发
*.egg
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
*.manifest
*.spec
dist/
build/
wheels/
share/python-wheels/

