# infra/docker 本地端口（宿主机端口冲突时可修改）
# 例：6333 已被占用时，将 QDRANT_HOST_PORT 改为 6335，并同步根 .env 中 QDRANT_URL

# --- 数据层宿主机端口 ---
MYSQL_HOST_PORT=13306
REDIS_HOST_PORT=6380
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
QDRANT_HOST_PORT=6335
OPENSEARCH_HOST_PORT=9201

# --- 数据层凭证 ---
MYSQL_ROOT_PASSWORD=lingprism
MYSQL_DATABASE=lingprism
MYSQL_USER=lingprism
MYSQL_PASSWORD=lingprism
NEO4J_USER=neo4j
NEO4J_PASSWORD=lingprism

# --- 全栈部署（--profile app）---
NGINX_HOST_PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# 前端构建时注入（浏览器访问 Nginx 入口）
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://user.localhost:8080,http://admin.localhost:8080,http://monitor.localhost:8080

# LLM（流式问答需配置智谱 API Key）
LLM_PROVIDER=zhipu
EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_DIM=1024
QDRANT_COLLECTION=lingprism_v1_zhipu_1024

# MCP
MCP_API_KEYS=dev-key-1,dev-key-2
MCP_PROTOCOL_VERSION=2025-03-26

LOG_LEVEL=info

# Go module proxy（Docker 构建 core 时使用；国内网络建议 goproxy.cn）
GOPROXY=https://goproxy.cn,direct

# npm / pnpm / pip 镜像（Docker 构建时使用；海外网络可改回官方源）
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
