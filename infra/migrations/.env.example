# infra/migrations — 数据库迁移
# 从仓库根目录或 infra/docker 读取 .env；未设置 DATABASE_URL 时使用 MYSQL_HOST_PORT（默认 3306）
#
# 若 docker compose 使用 infra/docker/.env.example（MYSQL_HOST_PORT=13306），
# 请确保 infra/docker/.env 已创建，或根目录 .env 中设置：
#   DATABASE_URL=mysql://lingprism:lingprism@localhost:13306/lingprism

DATABASE_URL=mysql://lingprism:lingprism@localhost:13306/lingprism
