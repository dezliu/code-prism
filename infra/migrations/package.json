{
  "name": "@lingprism/migrations",
  "private": true,
  "type": "module",
  "scripts": {
    "knex": "node --import tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts",
    "migrate": "npm run knex -- migrate:latest",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:status": "npm run knex -- migrate:status",
    "seed": "npm run knex -- seed:run"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
