# services/ai-worker — Celery + LangChain
LOG_LEVEL=info

# Redis — 端口须与 infra/docker REDIS_HOST_PORT 一致（默认 6380，避免宿主机 6379 冲突）
REDIS_HOST_PORT=6380
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

CORE_HTTP_URL=http://localhost:8080
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION=lingprism_v1_zhipu_1024
ZHIPU_EMBEDDING_DIM=1024

LLM_PROVIDER=zhipu
EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus
ZHIPU_EMBEDDING_MODEL=embedding-3
LLM_SCENE_INTENT_MODEL=glm-4-flash

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3003
