# services/core — Go 核心业务（本地开发默认对齐 infra/docker 端口映射）
LOG_LEVEL=info

# HTTP：Docker Nginx 占用 8080 时，core 会自动回退到 18080；也可显式指定
# CORE_HTTP_PORT=18080
CORE_GRPC_PORT=50051

# 数据层（Docker Compose 默认宿主机端口，见 infra/docker/.env.example）
MYSQL_HOST_PORT=13306
MYSQL_USER=lingprism
MYSQL_PASSWORD=lingprism
MYSQL_DATABASE=lingprism
# 或显式 DSN：MYSQL_DSN=lingprism:lingprism@tcp(localhost:13306)/lingprism?parseTime=true

REDIS_HOST_PORT=6380
QDRANT_HOST_PORT=6335
OPENSEARCH_HOST_PORT=9201

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lingprism
QDRANT_COLLECTION=lingprism_v1_zhipu_2048
ZHIPU_EMBEDDING_DIM=2048
INDEXER_GRPC_ADDR=localhost:50052
